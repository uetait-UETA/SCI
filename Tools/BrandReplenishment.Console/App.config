<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0" />
  </startup>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Toggle between TEST and PRODUCTION by commenting/uncommenting blocks.
       Currently set to: TEST (10.15.10.90)
       ═══════════════════════════════════════════════════════════════════════ -->

  <connectionStrings>
    <!-- TEST -->
    <add name="smm_latConnectionString"
         connectionString="Data Source=10.15.10.90;Initial Catalog=SMM_DFC;Persist Security Info=True;Max Pool Size=900;User ID=sa;Password=saPANECO2016!;Connection Timeout=300"
         providerName="System.Data.SqlClient" />
    <!--
    PRODUCTION
    <add name="smm_latConnectionString"
         connectionString="Data Source=172.18.58.1;Initial Catalog=smm_lat;Persist Security Info=True;Max Pool Size=900;User ID=sa;Password=Panama99!;Connection Timeout=300"
         providerName="System.Data.SqlClient" />
    -->
  </connectionStrings>

  <appSettings>
    <!-- SAP B1 company — matches Session["CompanyId"] in the web app -->
    <!-- TEST -->
    <add key="CompanyId" value="DFC_HOLDINGS" />
    <add key="SapDb"     value="DFC_HOLDINGS" />

    <!--
    PRODUCTION
    <add key="CompanyId" value="DFC_HOLDINGS" />
    <add key="SapDb"     value="DFC_HOLDINGS" />
    -->

    <!-- SAP Service Layer -->
    <!-- TEST -->
    <add key="SL_BaseUrl"  value="https://10.15.10.140:50000/b1s/v1" />
    <add key="SL_UserName" value="manager" />
    <add key="SL_Password" value="Colombia10" />

    <!--
    PRODUCTION
    <add key="SL_BaseUrl"  value="https://172.18.58.1:50000/b1s/v1" />
    <add key="SL_UserName" value="Manager" />
    <add key="SL_Password" value="Colombia10" />
    -->

    <!-- Transfer document series (same as CreateTransferSerieDoc in Web.config) -->
    <add key="CreateTransferSerieDoc" value="21" />

    <add key="whs_code" value="BODEGA" />
  </appSettings>
</configuration>
